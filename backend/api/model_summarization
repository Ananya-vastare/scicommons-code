# Load model once globally
model_name = "facebook/bart-large-cnn"
tokenizer = BartTokenizer.from_pretrained(model_name)
model = BartForConditionalGeneration.from_pretrained(model_name)

def clean_chat_text(chat_input):
    """Clean and prepare chat messages for summarization"""
    text = re.sub(r'@\w+', '', chat_input)
    text = re.sub(r'http\S+', '', text)
    text = re.sub(r'[^\w\s.!?]', '', text)
    text = re.sub(r'\s+', ' ', text).strip()
    return text

def summarize_chat(chat_text):
    """Generate summary from chat messages using BART model"""
    cleaned_text = clean_chat_text(chat_text)
    
    if not cleaned_text or len(cleaned_text.split()) < 10:
        return "Not enough content to summarize. Please enter more chat messages."
    
    try:
        inputs = tokenizer(
            cleaned_text,
            return_tensors="pt",
            max_length=1024,
            truncation=True
        )
        
        summary_ids = model.generate(
            inputs["input_ids"],
            max_length=500,
            min_length=30,
            early_stopping=True,
            forced_bos_token_id=0
        )
        
        summary = tokenizer.decode(summary_ids[0], skip_special_tokens=True)
        return summary
    
    except Exception as e:
        return f"Error generating summary: {str(e)}"
